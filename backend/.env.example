# Copy to .env and fill in.

# Postgres
DATABASE_URL=postgresql://strava_spoof:strava_spoof@localhost:5432/strava_spoof

# Google OAuth Web client ID. Create in Google Cloud Console → APIs & Services
# → Credentials → Create credentials → OAuth client ID → Web application.
# THIS MUST MATCH the value the Android app sends as setServerClientId(...)
# — same Web client ID on both sides.
GOOGLE_OAUTH_WEB_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# HTTP port
PORT=4000

# Max GPX upload size (bytes). 10 MB is plenty for a few-hour activity at 1 Hz.
MAX_UPLOAD_BYTES=10485760
