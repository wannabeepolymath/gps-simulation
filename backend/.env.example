# Copy to .env and fill in.

# Postgres
DATABASE_URL=postgresql://gps_simulator:gps_simulator@localhost:5432/gps_simulator

# Firebase Admin credentials — path to the service account JSON downloaded
# from Firebase console (Project settings → Service accounts → Generate
# new private key).
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# HTTP port to bind on
PORT=4000

# Max GPX upload size (bytes). 10 MB is plenty for a few-hour activity at 1 Hz.
MAX_UPLOAD_BYTES=10485760
